/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Inter", sans-serif;
}

body {
    background: #f5f6f7;
    color: #1f2937;
}

/* NAVBAR */
.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 60px;
    background: white;
    border-bottom: 1px solid #e5e7eb;
}

.logo {
    font-weight: 700;
    font-size: 20px;
    color: #111827;
}

.logo span {
    margin-left: 6px;
}

.menu a {
    margin: 0 14px;
    text-decoration: none;
    color: #374151;
    font-weight: 500;
}

.menu a:hover {
    color: #ff6a00;
}

.actions {
    display: flex;
    align-items: center;
    gap: 15px;
}

.login {
    text-decoration: none;
    color: #111827;
    font-weight: 500;
}

/* BOTÕES */
.btn-primary {
    background: #ff6a00;
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 25px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
}

.btn-primary:hover {
    background: #e85f00;
}

.btn-outline {
    background: transparent;
    border: 2px solid #d1d5db;
    padding: 12px 20px;
    border-radius: 25px;
    font-weight: 600;
    cursor: pointer;
}

.btn-outline:hover {
    border-color: #ff6a00;
    color: #ff6a00;
}

/* HERO */
.hero {
    text-align: center;
    padding: 100px 20px;
    max-width: 900px;
    margin: auto;
}

.tag {
    display: inline-block;
    background: #fff1e6;
    color: #ff6a00;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    margin-bottom: 25px;
}

.hero h1 {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 20px;
}

.hero h1 span {
    color: #ff6a00;
}

.hero p {
    color: #6b7280;
    font-size: 18px;
    margin-bottom: 35px;
}

.hero-buttons {
    display: flex;
    justify-content: center;
    gap: 20px;
}

.big {
    padding: 14px 26px;
    font-size: 16px;
}
